{
  "expo": {
    "name": "AquaAI",
    "slug": "aquaai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo.png",
    "scheme": "aquaai",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#040810"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/logo.png",
          "color": "#06B6D4"
        }
      ]
    ],
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/logo.png",
        "backgroundColor": "#040810"
      },
      "package": "com.aquaai.app"
    },
    "ios": {
      "bundleIdentifier": "com.aquaai.app",
      "supportsTablet": false
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "4fe63ec8-a73d-481f-9aba-881d04d75607"
      }
    }
  }
}
